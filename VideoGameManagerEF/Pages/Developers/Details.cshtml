@page "{id:int}"
@model VideoGameManager.Pages.Developers.DetailsDev
@{
    ViewData["Title"] = "Developer Details";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="./Index">Developers</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Developer.Name</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 overflow-hidden">
                <div class="card-header bg-primary text-white py-4 text-center">
                    <i class="bi bi-buildings-fill display-4 mb-2"></i>
                    <h2 class="fw-bold mb-0">@Model.Developer.Name</h2>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3">
                        <label class="text-muted small text-uppercase fw-bold">Developer ID</label>
                        <p class="mb-0">#@Model.Developer.Id</p>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted small text-uppercase fw-bold">Portfolio Size</label>
                        <p class="mb-0">
                            <span class="badge bg-info-subtle text-info px-3">
                                @Model.Developer.Games.Count Games Developed
                            </span>
                        </p>
                    </div>
                    
                    <hr class="my-4">
                    
                    <div class="d-grid gap-2">
                        <a asp-page="./Index" class="btn btn-light">
                            <i class="bi bi-arrow-left me-2"></i>Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-dark">
                        <i class="bi bi-controller me-2"></i>Games Developed by @Model.Developer.Name
                    </h5>
                </div>
                <div class="card-body p-0">
                    @if (Model.Developer.Games.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light text-uppercase">
                                    <tr>
                                        <th class="ps-4">Title</th>
                                        <th class="text-center">Year</th>
                                        <th class="text-center">Genre</th>
                                        <th class="text-center">Score</th>
                                        <th class="pe-4 text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var game in Model.Developer.Games.OrderByDescending(g => g.Year))
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <span class="fw-bold text-dark">@game.Title</span>
                                            </td>
                                            <td class="text-center">@game.Year</td>
                                            <td class="text-center">
                                                <span class="badge bg-secondary-subtle text-secondary fw-normal">@game.Genre</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="fw-bold @(game.Score >= 8 ? "text-success" : "text-warning")">
                                                    @game.Score.ToString("F1")
                                                </span>
                                            </td>
                                            <td class="pe-4 text-end">
                                                <a asp-page="/Games/Details" asp-route-id="@game.Id" class="btn btn-sm btn-outline-secondary" title="View Game">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-info-circle text-muted display-6"></i>
                            <p class="mt-3 text-muted">This developer has no games registered yet.</p>
                            <a asp-page="/Games/Create" class="btn btn-sm btn-primary mt-2">Add New Game</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f8f9fa; }
    .card { border-radius: 12px; }
    .breadcrumb-item a { text-decoration: none; color: #6c757d; }
    .breadcrumb-item.active { color: #0d6efd; font-weight: 600; }
    .table thead th { font-size: 0.75rem; letter-spacing: 0.5px; }
</style>