@page
@model VideoGameManager.Pages.Developers.IndexDev

@{
    ViewData["Title"] = "Developers";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Developers</h1>
        <p class="lead text-muted">See all available developers</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h4 class="mb-0 fw-bold text-dark">
                        @if (Model.Developers.Count == 0)
                        {
                            <span>No Developers Found</span>
                        }
                        else
                        {
                            <span>Registered Developers (@Model.Developers.Count)</span>
                        }
                    </h4>
                </div>
                
                <div class="card-body p-0">
                    @if (Model.Developers.Count == 0)
                    {
                        <div class="text-center py-5">
                            <p class="text-muted fs-5">Your library is currently empty. Start by adding your first game!</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Name</th>
                                        <th>Country</th>
                                        <th class="text-center">Year</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var developer in Model.Developers)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold text-dark">@developer.Name</td>
                                        <td><span class="badge bg-info text-dark fw-normal">@developer.Country</span></td>
                                        <td class="text-center">@developer.FoundedYear</td>
                                        <td class="text-center pe-4">
                                            <div class="btn-group btn-group-sm">
                                                <a asp-page="/Developers/Details" asp-route-id="@developer.Id" class="btn btn-outline-secondary">Details</a>
                                                <a asp-page="/Developers/Delete" asp-route-id="@developer.Id" class="btn btn-outline-danger">Delete</a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.03);
        transition: background-color 0.2s ease;
    }

    .text-truncate {
        display: inline-block;
        vertical-align: middle;
    }

    .card {
        border-radius: 12px;
        overflow: hidden;
    }

    .table thead th {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
        padding-top: 15px;
        padding-bottom: 15px;
    }
</style>