@page
@model VideoGameManagerEF.Pages.Games.DeleteModel

@{
    ViewData["Title"] = "Delete Game";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Index" class="text-decoration-none">Library</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Delete Confirmation</li>
                </ol>
            </nav>

            <div class="card shadow border-0">
                <div class="card-header bg-danger py-3">
                    <h4 class="mb-0 text-white text-center fw-bold">Confirm Deletion</h4>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <p class="text-muted text-uppercase small fw-bold mb-2">You are about to remove</p>
                        <h1 class="display-6 fw-bold text-dark">@Model.Game?.Title</h1>
                    </div>

                    <div class="bg-light rounded p-3 mb-4 border">
                        <div class="row small text-secondary">
                            <div class="col-6 mb-2">
                                <strong>Genre:</strong> @Model.Game?.Genre
                            </div>
                            <div class="col-6 mb-2 text-end">
                                <strong>Year:</strong> @Model.Game?.Year
                            </div>
                            <div class="col-12">
                                <strong>Description:</strong> 
                                <p class="mb-0 text-truncate-2">@Model.Game?.Description</p>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-warning border-0 shadow-sm mb-4">
                        <strong>Warning:</strong> This action cannot be undone. All data associated with this game will be permanently removed.
                    </div>

                    <form method="post">
                        <input type="hidden" asp-for="Game!.Id" />
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg fw-bold">Permanently Delete</button>
                            <a asp-page="/Games/Index" class="btn btn-outline-secondary">Cancel and Go Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Styling for the delete confirmation */
    .card {
        border-radius: 1rem;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: ">";
    }

    /* Limit description length in the summary */
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }

    /* Red focus for the delete button */
    .btn-danger:focus {
        box-shadow: 0 0 0 0.25rem rgba(220, 53, 69, 0.25);
    }
</style>