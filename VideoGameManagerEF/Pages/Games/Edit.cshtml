@page
@model VideoGameManagerEF.Pages.Games.EditModel

@{
    ViewData["Title"] = "Edit Game";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-page="/Games/Index" class="text-decoration-none">Library</a></li>
                    <li class="breadcrumb-item"><a asp-page="/Games/Details" asp-route-id="@Model.Game?.Id" class="text-decoration-none">Details</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Edit Game</li>
                </ol>
            </nav>

            <div class="card shadow border-0">
                <div class="card-header bg-primary py-3">
                    <h4 class="mb-0 text-white text-center fw-bold">Update Game Information</h4>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form method="post">
                        <div asp-validation-summary="All" class="alert alert-danger border-0 shadow-sm mb-4" role="alert"></div>
                        
                        <input type="hidden" asp-for="Game!.Id" />

                        <div class="mb-3">
                            <label asp-for="Game!.Title" class="form-label fw-bold text-secondary">Game Title</label>
                            <input asp-for="Game!.Title" class="form-control form-control-lg" />
                            <span asp-validation-for="Game!.Title" class="text-danger small"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Game!.Genre" class="form-label fw-bold text-secondary">Genre</label>
                                <input asp-for="Game!.Genre" class="form-control" />
                                <span asp-validation-for="Game!.Genre" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="Game!.Year" class="form-label fw-bold text-secondary">Release Year</label>
                                <input asp-for="Game!.Year" class="form-control" />
                                <span asp-validation-for="Game!.Year" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Game!.Score" class="form-label fw-bold text-secondary">Score Rating</label>
                            <input asp-for="Game!.Score" class="form-control" />
                            <span asp-validation-for="Game!.Score" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Game!.Description" class="form-label fw-bold text-secondary">Description</label>
                            <textarea asp-for="Game!.Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Game!.Description" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg fw-bold">Save Changes</button>
                            <a asp-page="/Games/Index" class="btn btn-outline-secondary">Discard Changes</a>
                        </div>
                    </form>
                </div>
                
                <div class="card-footer bg-light text-center py-3">
                    <small class="text-muted">Editing: <strong>@Model.Game?.Title</strong></small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
    .card {
        border-radius: 1rem;
    }
    
    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15);
    }

    .form-label {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.8px;
    }

    .breadcrumb-item + .breadcrumb-item::before {
        content: ">";
    }

    body {
        background-color: #fcfcfc;
    }
</style>