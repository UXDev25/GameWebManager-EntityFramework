@page
@model VideoGameManagerEF.Pages.Stats.IndexStats
@{
    ViewData["Title"] = "Game Analytics & Stats";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<div class="container py-5">
    <div class="text-center mb-5">
        <span class="badge rounded-pill bg-primary-subtle text-primary px-3 py-2 mb-2 text-uppercase fw-bold">Dashboard</span>
        <h1 class="display-4 fw-bold">Game Analytics</h1>
        <p class="lead text-muted">Explore data, statistics, and rankings from your collection.</p>
    </div>

    <div class="row g-4">
        
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-search me-2"></i>Search Filters</h5>
                </div>
                <div class="card-body">
                    <form method="get">
                        <div class="mb-4">
                            <label asp-for="SelectedTitle" class="form-label fw-bold">Game Title</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-controller"></i></span>
                                <input asp-for="SelectedTitle" class="form-control" placeholder="Ex: Zelda...">
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Genre</label>
                            <select asp-for="SelectedGenreFilter" class="form-select">
                                <option value="">All Genres</option>
                                @foreach (var genre in Model.Genres)
                                {
                                    <option value="@genre">@genre</option>
                                }
                            </select>
                        </div>

                        <div class="mb-4">
                            <label asp-for="SelectedMinYear" class="form-label fw-bold">Minimum Year</label>
                            <input asp-for="SelectedMinYear" type="number" class="form-control" placeholder="YYYY">
                        </div>

                        <button type="submit" class="btn btn-primary w-100 fw-bold py-2">
                            <i class="bi bi-filter me-2"></i>Apply Filters
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 text-primary fw-bold">Search Results</h5>
                    <span class="badge bg-light text-dark border">@Model.GameResults.Count games found</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 500px;">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th class="ps-3">Title</th>
                                    <th>Year/Genre</th>
                                    <th class="text-center">Score</th>
                                    <th class="text-end pe-3">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var game in Model.GameResults)
                                {
                                    <tr>
                                        <td class="ps-3">
                                            <div class="fw-bold">@game.Title</div>
                                            <small class="text-muted">@game.Developer?.Name</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary-subtle text-secondary mb-1">@game.Year</span><br>
                                            <small class="text-info text-uppercase fw-bold" style="font-size: 0.7rem;">@game.Genre</small>
                                        </td>
                                        <td class="text-center">
                                            <div class="p-2 rounded-circle d-inline-block @(game.Score >= 8 ? "bg-success-subtle text-success" : "bg-warning-subtle text-warning")" style="width: 45px; height: 45px; line-height: 30px;">
                                                <span class="fw-bold">@game.Score.ToString("F1")</span>
                                            </div>
                                        </td>
                                        <td class="text-end pe-3">
                                            <div class="btn-group btn-group-sm">
                                                <a asp-page="/Games/Details" asp-route-id="@game.Id" class="btn btn-light border" title="Details"><i class="bi bi-eye"></i></a>
                                                <a asp-page="/Games/Edit" asp-route-id="@game.Id" class="btn btn-light border" title="Edit"><i class="bi bi-pencil"></i></a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-dark text-white py-3">
                    <h5 class="mb-0"><i class="bi bi-trophy me-2 text-warning"></i>Top 5 Best Games</h5>
                </div>
                <div class="list-group list-group-flush">
                    @for (int i = 0; i < Model.TopGames.Count; i++)
                    {
                        var game = Model.TopGames[i];
                        <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                            <div>
                                <span class="badge bg-warning text-dark me-2">#@(i + 1)</span>
                                <span class="fw-bold">@game.Title</span>
                            </div>
                            <span class="badge rounded-pill bg-success">@game.Score.ToString("F1")</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-calendar3 me-2 text-primary"></i>Games per Decade</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        @foreach (var decade in Model.DecadeGames)
                        {
                            <div class="col-4 mb-3">
                                <div class="p-3 border rounded bg-light shadow-sm-hover">
                                    <h6 class="text-muted mb-1 small text-uppercase">@decade.Decade's</h6>
                                    <h4 class="fw-bold mb-0 text-primary">@decade.Count</h4>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 mt-4">
            <div class="card shadow-sm border-0 overflow-hidden">
                <div class="card-header bg-secondary text-white py-3">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <h5 class="mb-0 fw-bold"><i class="bi bi-buildings me-2"></i>Developer Performance</h5>
                        </div>
                        <div class="col-md-6">
                            <form method="get" class="d-flex gap-2 justify-content-md-end mt-2 mt-md-0">
                                <div class="input-group input-group-sm w-auto">
                                    <span class="input-group-text bg-light border-0">Min. Games:</span>
                                    <input asp-for="DevGamesSort" class="form-control" style="width: 80px;" placeholder="0">
                                    <button type="submit" class="btn btn-primary btn-sm px-3">Filter</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light text-uppercase">
                                <tr>
                                    <th class="ps-4">Developer Name</th>
                                    <th class="text-center">Average Score</th>
                                    <th class="text-center">Catalog Size</th>
                                    <th class="pe-4">Score Progress</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var dev in Model.AvgDevelopers)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold text-dark">@dev.Name</td>
                                        <td class="text-center">
                                            <span class="badge bg-primary px-3">@dev.AvgScore.ToString("F2")</span>
                                        </td>
                                        <td class="text-center">@dev.GameCount games</td>
                                        <td class="pe-4" style="width: 25%;">
                                            <div class="progress shadow-sm" style="height: 10px;" title="@dev.AvgScore / 10">
                                                <div class="progress-bar bg-info" role="progressbar" 
                                                     style="width: @(dev.AvgScore * 10)%;" 
                                                     aria-valuenow="@dev.AvgScore" aria-valuemin="0" aria-valuemax="10"></div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    body { background-color: #f0f2f5; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
    .card { border-radius: 12px; transition: transform 0.2s ease; }
    .table thead th { font-size: 0.7rem; letter-spacing: 1px; color: #6c757d; font-weight: 700; }
    .bg-primary { background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%) !important; }
    .progress { border-radius: 10px; background-color: #e9ecef; }
    .shadow-sm-hover:hover { background-color: #ffffff !important; box-shadow: 0 .125rem .25rem rgba(0,0,0,.075)!important; }
    .sticky-top { z-index: 10; }
</style>